# AI
GOOGLE_GENERATIVE_AI_API_KEY=

# Database connection string (PostgreSQL)
# You can use a local database or a cloud provider like Neon/Supabase
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# Clerk Authentication Keys
# Get these from your Clerk dashboard (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"
CLERK_SECRET_KEY="your_clerk_secret_key"

# Secret used to authorize the daily cron job that purges soft-deleted
# accounts older than 30 days. Use any long random string.
CRON_SECRET="your_random_cron_secret"